generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserSex {
  MALE
  FEMALE
}

enum ConditionDataType {
  NUMBER
  STRING
  UUID
  ENUM
}

enum ConditionOperator {
  EQ
  NEQ
  GT
  GTE
  LT
  LTE
}

enum LogicalOperator {
  AND
  OR
}

enum WalletTxType {
  CREDIT
  DEBIT
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum RevenueValueType {
  NUMBER_RANGE
  TIME_RANGE
  ENUM
}

enum UserMembershipStatus {
  PENDING
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  MERCADOPAGO
  TRANSFER
  CASH
  WALLET
}

enum PaymentStatus {
  PENDING_PROOF
  PENDING_VALIDATION
  APPROVED
  REJECTED
  REFUNDED
  PENDING_CASH
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  firstName     String     @map("first_name")
  lastName      String     @map("last_name")
  status        UserStatus @default(ACTIVE)
  tokenVersion  Int        @default(0) @map("token_version")
  sex           UserSex?   @map("sex")
  birthDate     DateTime?  @map("birth_date")
  handicap      Int?       @map("handicap")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  userRoles       UserRole[]
  passwordResets  PasswordReset[]
  userMemberships UserMembership[]
  bookings        Booking[]
  wallet          UserWallet?

  suspensions        UserSuspension[] @relation("UserSuspensions")
  suspensionsCreated UserSuspension[] @relation("SuspensionCreatedBy")
  suspensionsLifted  UserSuspension[] @relation("SuspensionLiftedBy")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  grantedAt    DateTime @default(now()) @map("granted_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ─── System ───────────────────────────────────────────────────────────────────

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  label     String?
  group     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

// ─── Sport Types & Venues ────────────────────────────────────────────────────

model SportType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  venues             Venue[]
  membershipPlans    MembershipPlan[]
  blockedPeriods     BlockedPeriod[]
  pricingConfigs     PricingConfig[]
  additionalServices AdditionalService[]
  sportPrices        MembershipPlanSportPrice[]

  @@map("sport_types")
}

model Venue {
  id          String   @id @default(uuid())
  sportTypeId String   @map("sport_type_id")
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sportType      SportType             @relation(fields: [sportTypeId], references: [id])
  schedules      VenueSchedule[]
  slots          Slot[]
  blockedPeriods BlockedPeriod[]
  operatingHours VenueOperatingHours[]

  @@map("venues")
}

model VenueOperatingHours {
  id         String @id @default(uuid())
  venueId    String @map("venue_id")
  daysOfWeek Int[]  @map("days_of_week")
  openTime   String @map("open_time")
  closeTime  String @map("close_time")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("venue_operating_hours")
}

// ─── Memberships ──────────────────────────────────────────────────────────────

model MembershipPlan {
  id                      String   @id @default(uuid())
  name                    String   @unique
  description             String?
  price                   Decimal  @db.Decimal(10, 2)
  monthlyReservationLimit Int?     @map("monthly_reservation_limit")
  sportTypeId             String?  @map("sport_type_id")
  active                  Boolean  @default(true)
  // Wallet: acreditación al pagar mensualidad
  walletCreditEnabled     Boolean  @default(false) @map("wallet_credit_enabled")
  walletCreditAmount      Decimal? @db.Decimal(10, 2) @map("wallet_credit_amount")
  // Wallet: uso como medio de pago al reservar
  walletPaymentEnabled    Boolean  @default(false) @map("wallet_payment_enabled")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  sportType       SportType?                 @relation(fields: [sportTypeId], references: [id])
  userMemberships UserMembership[]
  sportPrices     MembershipPlanSportPrice[]

  @@map("membership_plans")
}

model MembershipPlanSportPrice {
  id               String  @id @default(uuid())
  membershipPlanId String  @map("membership_plan_id")
  sportTypeId      String  @map("sport_type_id")
  baseBookingPrice Decimal @db.Decimal(10, 2) @map("base_booking_price")

  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id], onDelete: Cascade)
  sportType      SportType      @relation(fields: [sportTypeId], references: [id])

  @@unique([membershipPlanId, sportTypeId])
  @@map("membership_plan_sport_prices")
}

model UserMembership {
  id                    String               @id @default(uuid())
  userId                String               @map("user_id")
  membershipPlanId      String               @map("membership_plan_id")
  status                UserMembershipStatus @default(ACTIVE)
  startDate             DateTime             @map("start_date")
  endDate               DateTime?            @map("end_date")
  reservationsUsedMonth Int                  @default(0) @map("reservations_used_month")
  currentMonthYear      String?              @map("current_month_year")
  notes                 String?
  mpSubscriptionId      String?              @map("mp_subscription_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id])

  @@map("user_memberships")
}

// ─── Wallet ───────────────────────────────────────────────────────────────────

model UserWallet {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("user_wallets")
}

model WalletTransaction {
  id            String       @id @default(uuid())
  walletId      String       @map("wallet_id")
  amount        Decimal      @db.Decimal(10, 2)
  type          WalletTxType
  description   String?
  referenceType String?      @map("reference_type")
  referenceId   String?      @map("reference_id")
  createdAt     DateTime     @default(now()) @map("created_at")

  wallet UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

// ─── Schedule Rules (Condition Types) ────────────────────────────────────────

model ConditionType {
  id               String            @id @default(uuid())
  name             String
  key              String            @unique
  dataType         ConditionDataType
  allowedOperators String[]          @map("allowed_operators")
  allowedValues    Json?             @map("allowed_values")
  isSystem         Boolean           @default(false) @map("is_system")
  description      String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  ruleConditions ScheduleRuleCondition[]

  @@map("condition_types")
}

// ─── Venue Schedules & Slots ──────────────────────────────────────────────────

model BlockedPeriod {
  id          String    @id @default(uuid())
  sportTypeId String?   @map("sport_type_id")
  venueId     String?   @map("venue_id")
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  startTime   String?   @map("start_time")
  endTime     String?   @map("end_time")
  reason      String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sportType SportType? @relation(fields: [sportTypeId], references: [id])
  venue     Venue?     @relation(fields: [venueId], references: [id])

  @@map("blocked_periods")
}

model VenueSchedule {
  id             String    @id @default(uuid())
  venueId        String    @map("venue_id")
  name           String
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  generatedUntil DateTime? @map("generated_until")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  venue      Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  slots      Slot[]
  timeRanges ScheduleTimeRange[]

  @@map("venue_schedules")
}

model ScheduleTimeRange {
  id              String   @id @default(uuid())
  scheduleId      String   @map("schedule_id")
  daysOfWeek      Int[]    @map("days_of_week")
  startTime       String   @map("start_time")
  endTime         String   @map("end_time")
  intervalMinutes Int      @map("interval_minutes")
  playersPerSlot  Int      @map("players_per_slot")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  schedule VenueSchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  rules    ScheduleRule[]
  slots    Slot[]

  @@map("schedule_time_ranges")
}

model ScheduleRule {
  id                       String   @id @default(uuid())
  timeRangeId              String   @map("time_range_id")
  canBook                  Boolean  @default(true) @map("can_book")
  priceOverride            Decimal? @db.Decimal(10, 2) @map("price_override")
  revenueManagementEnabled Boolean  @default(false) @map("revenue_management_enabled")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  timeRange  ScheduleTimeRange      @relation(fields: [timeRangeId], references: [id], onDelete: Cascade)
  conditions ScheduleRuleCondition[]

  @@map("schedule_rules")
}

model ScheduleRuleCondition {
  id              String            @id @default(uuid())
  ruleId          String            @map("rule_id")
  conditionTypeId String            @map("condition_type_id")
  operator        ConditionOperator
  value           String
  logicalOperator LogicalOperator?  @map("logical_operator")
  order           Int               @default(0)
  createdAt       DateTime          @default(now()) @map("created_at")

  rule          ScheduleRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  conditionType ConditionType @relation(fields: [conditionTypeId], references: [id])

  @@map("schedule_rule_conditions")
}

model Slot {
  id          String     @id @default(uuid())
  venueId     String     @map("venue_id")
  scheduleId  String     @map("schedule_id")
  timeRangeId String?    @map("time_range_id")
  date        DateTime   @map("date") @db.Date
  startTime   String     @map("start_time")
  endTime     String     @map("end_time")
  status      SlotStatus @default(AVAILABLE)
  createdAt   DateTime   @default(now()) @map("created_at")

  venue     Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  schedule  VenueSchedule      @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  timeRange ScheduleTimeRange? @relation(fields: [timeRangeId], references: [id], onDelete: SetNull)
  booking   Booking?

  // Permitir múltiples slots por (venue, fecha, hora) de distintos schedules
  @@unique([venueId, date, startTime, scheduleId])
  @@map("slots")
}

// ─── Additional Services ──────────────────────────────────────────────────────

model AdditionalService {
  id          String   @id @default(uuid())
  sportTypeId String?  @map("sport_type_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sportType       SportType?       @relation(fields: [sportTypeId], references: [id])
  bookingServices BookingService[]

  @@map("additional_services")
}

// ─── Bookings & Payments ──────────────────────────────────────────────────────

model Booking {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  slotId           String        @unique @map("slot_id")
  membershipPlanId String?       @map("membership_plan_id")
  status           BookingStatus @default(PENDING_PAYMENT)
  price            Decimal       @db.Decimal(10, 2)
  isMemberPrice    Boolean       @default(false) @map("is_member_price")
  qrCode           String?       @unique @map("qr_code")
  qrValidatedAt    DateTime?     @map("qr_validated_at")
  notes            String?
  numPlayers       Int           @default(1) @map("num_players")
  cancelledAt      DateTime?     @map("cancelled_at")
  cancelledBy      String?       @map("cancelled_by")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id])
  slot            Slot             @relation(fields: [slotId], references: [id])
  payment         Payment?
  bookingServices BookingService[]

  @@map("bookings")
}

model BookingService {
  id        String   @id @default(uuid())
  bookingId String   @map("booking_id")
  serviceId String   @map("service_id")
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service AdditionalService @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
  @@map("booking_services")
}

model Payment {
  id                       String        @id @default(uuid())
  bookingId                String        @unique @map("booking_id")
  method                   PaymentMethod
  status                   PaymentStatus
  amount                   Decimal       @db.Decimal(10, 2)
  mpPaymentId              String?       @map("mp_payment_id")
  transferProofUrl         String?       @map("transfer_proof_url")
  transferProofUploadedAt  DateTime?     @map("transfer_proof_uploaded_at")
  expiresAt                DateTime?     @map("expires_at")
  approvedByUserId         String?       @map("approved_by_user_id")
  approvedAt               DateTime?     @map("approved_at")
  rejectionReason          String?       @map("rejection_reason")
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PricingConfig {
  id          String   @id @default(uuid())
  sportTypeId String   @unique @map("sport_type_id")
  basePrice   Decimal  @db.Decimal(10, 2) @default(0)
  minPrice    Decimal  @db.Decimal(10, 2) @default(0)
  maxPrice    Decimal  @db.Decimal(10, 2) @default(999999)
  roundingStep Int     @default(0) @map("rounding_step")
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sportType SportType       @relation(fields: [sportTypeId], references: [id])
  factors   RevenueFactor[]

  @@map("pricing_configs")
}

model RevenueFactorType {
  id          String           @id @default(uuid())
  name        String
  key         String           @unique
  valueType   RevenueValueType @map("value_type")
  enumValues  String[]         @default([]) @map("enum_values")
  enumLabels  String[]         @default([]) @map("enum_labels")
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  factors RevenueFactor[]

  @@map("revenue_factor_types")
}

model RevenueFactor {
  id              String   @id @default(uuid())
  pricingConfigId String   @map("pricing_config_id")
  factorTypeId    String   @map("factor_type_id")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  pricingConfig PricingConfig       @relation(fields: [pricingConfigId], references: [id], onDelete: Cascade)
  factorType    RevenueFactorType   @relation(fields: [factorTypeId], references: [id], onDelete: Cascade)
  rules         RevenueFactorRule[]

  @@unique([pricingConfigId, factorTypeId])
  @@map("revenue_factors")
}

// ─── User Suspensions ─────────────────────────────────────────────────────────

model UserSuspension {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  reason      String
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  isAutomatic Boolean   @default(false) @map("is_automatic")
  liftedAt    DateTime? @map("lifted_at")
  liftedById  String?   @map("lifted_by_id")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user      User  @relation("UserSuspensions", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User  @relation("SuspensionCreatedBy", fields: [createdById], references: [id])
  liftedBy  User? @relation("SuspensionLiftedBy", fields: [liftedById], references: [id])

  @@map("user_suspensions")
}

model RevenueFactorRule {
  id         String   @id @default(uuid())
  factorId   String   @map("factor_id")
  minValue   String?  @map("min_value")
  maxValue   String?  @map("max_value")
  enumValue  String?  @map("enum_value")
  multiplier Decimal  @db.Decimal(5, 2)
  label      String?
  createdAt  DateTime @default(now()) @map("created_at")

  factor RevenueFactor @relation(fields: [factorId], references: [id], onDelete: Cascade)

  @@map("revenue_factor_rules")
}
